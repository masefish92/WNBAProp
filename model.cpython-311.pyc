"""Download WNBA schedule/result data from the sportsdataverse wehoop project.

Source: https://github.com/sportsdataverse/wehoop-wnba-raw (ESPN data,
refreshed daily by the sportsdataverse GitHub Actions). Each season file
contains every game with date, teams, venue, final scores, and status.
"""

import sys
import urllib.request
from pathlib import Path

BASE = (
    "https://raw.githubusercontent.com/sportsdataverse/wehoop-wnba-raw/"
    "main/wnba/schedules/parquet/wnba_schedule_{year}.parquet"
)
DATA_DIR = Path(__file__).resolve().parent.parent / "data"

FIRST_SEASON = 2010


def fetch(year: int, force: bool = False) -> Path:
    dest = DATA_DIR / f"wnba_schedule_{year}.parquet"
    if dest.exists() and not force:
        return dest
    url = BASE.format(year=year)
    print(f"fetching {url}")
    with urllib.request.urlopen(url, timeout=60) as resp:
        dest.write_bytes(resp.read())
    return dest


def fetch_all(current_year: int, force_current: bool = True) -> list[Path]:
    """Fetch all seasons; past seasons are cached, current season is refreshed."""
    DATA_DIR.mkdir(exist_ok=True)
    paths = []
    for year in range(FIRST_SEASON, current_year + 1):
        try:
            paths.append(fetch(year, force=force_current and year == current_year))
        except Exception as exc:  # a missing future season is fine
            print(f"warning: could not fetch {year}: {exc}", file=sys.stderr)
    return paths


if __name__ == "__main__":
    import datetime

    year = int(sys.argv[1]) if len(sys.argv) > 1 else datetime.date.today().year
    fetch_all(year)
